# SETUP: Copy this file to ~/.secrets and fill in your values:
#   cp ~/dev/dotfiles/.secrets.template ~/.secrets
#   chmod 600 ~/.secrets
#   vim ~/.secrets
#
# For project-specific secrets, use ~/.bash_local instead.

