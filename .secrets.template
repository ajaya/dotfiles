# ~/.secrets - Sensitive credentials and API tokens
# This file should have restricted permissions (chmod 600)
#
# SETUP: Copy this file to ~/.secrets and fill in your values:
#   cp ~/dev/dotfiles/.secrets.template ~/.secrets
#   chmod 600 ~/.secrets
#   vim ~/.secrets
#
# For project-specific secrets, use ~/.bash_local instead.

# GITHUB
export HOMEBREW_GITHUB_API_TOKEN=""
export CR_PAT=""

# BITWARDEN
# Short-lived session token. Prefer exporting this only in the shell that needs
# it instead of keeping a long-lived value here:
#   export BW_SESSION="$(bw unlock --raw)"
# BW_SESSION=""

# OPENAI
# Prefer short-lived shell-local exports for API keys unless a tool needs them
# in every login shell.
# export OPENAI_API_KEY=""

# Add project-specific secrets in ~/.bash_local
